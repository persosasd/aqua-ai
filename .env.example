# .env.example — Copy this to .env and fill in real values

# Database Configuration
DB_NAME=aqua_ai_db
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
# DATABASE_URL is constructed in docker-compose, but if running locally:
DATABASE_URL=postgresql://postgres:CHANGE_ME_TO_A_STRONG_PASSWORD@localhost:5432/aqua_ai_db
SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY is recommended for backend access (bypasses RLS)
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# Security & Authentication
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
JWT_EXPIRES_IN=7d
NODE_ENV=production

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# API Keys
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here
DATA_GOV_IN_RESOURCE_ID=f83158c9-ff64-4ef5-ae8c-c76baf56dae3
WEATHER_API_KEY=your_weather_api_key_here
MAPS_API_KEY=your_maps_api_key_here

# AI Model Configuration
MODEL_VERSION=1.0.0
PREDICTION_CONFIDENCE_THRESHOLD=0.7

# Alert System
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
ALERT_EMAIL_USER=your_email@gmail.com
ALERT_EMAIL_PASSWORD=your_email_password

# Data Pipeline Configuration
DATA_FETCH_INTERVAL_HOURS=24
DATA_RETENTION_DAYS=365
ALLOW_SAMPLE_DATA=false
DATA_PIPELINE_ON_START=false
DATA_PIPELINE_PYTHON=python
# DATA_PIPELINE_SCRIPT=/absolute/path/to/data-pipeline/fetch_data.py

# Logging
LOG_LEVEL=info
